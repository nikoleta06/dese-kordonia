{% block head_extra2 %}
  <style>
    .zones { margin-top: 1.2rem; display: flex; flex-direction: column; gap: 0.7rem; }
    .zone { background: var(--surface-2); border-left: 4px solid var(--accent); border-radius: 8px; padding: 0.8rem 1rem; }
    .zone .z-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; }
    .zone .z-name { font-family: "Oswald", sans-serif; color: var(--text); font-size: 1.02rem; letter-spacing: 0.3px; }
    .zone .z-bpm { font-family: "Oswald", sans-serif; color: var(--accent-2); font-weight: 600; white-space: nowrap; }
    .zone .z-desc { color: var(--text-dim); font-size: 0.9rem; margin: 0.35rem 0 0; }
    .zone.z1 { border-left-color: #4aa3ff; }
    .zone.z2 { border-left-color: #2ecc71; }
    .zone.z3 { border-left-color: #f1c40f; }
    .zone.z4 { border-left-color: #ff9800; }
    .zone.z5 { border-left-color: #e24b4a; }
    .maxhr-line { margin-top: 0.5rem; color: var(--text-dim); }
    .maxhr-line strong { color: var(--accent); font-size: 1.15rem; }
  </style>
{% endblock %}

{% block content %}
  <main>
    <h1 class="section-title">Ζώνες Καρδιακών Παλμών</h1>
    <p class="lead">
      Οι ζώνες παλμών σε βοηθούν να προπονείσαι σωστά: άλλοτε χαλαρά για αντοχή, άλλοτε έντονα
      για ταχύτητα. Βάλε την ηλικία σου (και προαιρετικά τους παλμούς ηρεμίας για πιο ακριβές
      αποτέλεσμα) και δες τις 5 ζώνες σου.
    </p>

    <div class="calc">
      <div class="field">
        <label for="age">Ηλικία</label>
        <input type="number" id="age" min="5" max="120" step="1" placeholder="π.χ. 30">
      </div>

      <div class="field">
        <label for="resting">Παλμοί ηρεμίας <span style="color:var(--text-dim); font-weight:400;">(προαιρετικό)</span></label>
        <input type="number" id="resting" min="30" max="120" step="1" placeholder="π.χ. 60">
        <small>Μέτρησέ τους το πρωί, ξεκούραστη, πριν σηκωθείς από το κρεβάτι.</small>
      </div>

      <button class="btn" id="calcBtn" type="button">Υπολόγισε</button>

      <div class="calc-result calc-hidden" id="result">
        <p class="maxhr-line">Εκτιμώμενοι μέγιστοι παλμοί: <strong id="maxhrVal">--</strong> bpm <span id="method" style="font-size:0.85rem;"></span></p>
        <div class="zones" id="zones"></div>
        <p class="image-credit" style="margin-top:1rem;">* Ενδεικτικός υπολογισμός. Δεν αντικαθιστά ιατρική συμβουλή — αν έχεις θέμα υγείας, συμβουλέψου γιατρό.</p>
      </div>
    </div>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);

      function calculate() {
        const age = parseInt($('age').value);
        const rest = parseInt($('resting').value) || 0;
        if (!age || age < 5 || age > 120) {
          alert('Βάλε έγκυρη ηλικία (5–120).');
          return;
        }
        const maxHR = Math.round(208 - 0.7 * age); // φόρμουλα Tanaka
        const useHRR = rest > 0 && rest < maxHR;
        $('maxhrVal').textContent = maxHR;
        $('method').textContent = useHRR ? '(μέθοδος Karvonen)' : '(% μέγιστων παλμών)';

        const zones = [
          { n: 'Ζώνη 1 · Ανάκαμψη', lo: 0.50, hi: 0.60, d: 'Πολύ χαλαρό. Ζέσταμα, αποθεραπεία και ενεργητική ανάκαμψη.' },
          { n: 'Ζώνη 2 · Αερόβια βάση', lo: 0.60, hi: 0.70, d: 'Άνετο τρέξιμο όπου μπορείς να μιλάς. Εδώ χτίζεται η αντοχή — οι περισσότερες προπονήσεις.' },
          { n: 'Ζώνη 3 · Tempo', lo: 0.70, hi: 0.80, d: 'Μέτρια έως έντονη προσπάθεια. Βελτιώνει την αερόβια ικανότητα.' },
          { n: 'Ζώνη 4 · Όριο (threshold)', lo: 0.80, hi: 0.90, d: 'Σκληρή προσπάθεια κοντά στο γαλακτικό κατώφλι. Ανεβάζει την ταχύτητα αντοχής.' },
          { n: 'Ζώνη 5 · Μέγιστη', lo: 0.90, hi: 1.00, d: 'Πολύ έντονα, σύντομα διαστήματα. Βελτιώνει το VO₂max και την ταχύτητα.' }
        ];

        const hr = (p) => useHRR ? Math.round(rest + p * (maxHR - rest)) : Math.round(p * maxHR);

        $('zones').innerHTML = zones.map((z, i) =>
          '<div class="zone z' + (i + 1) + '">' +
            '<div class="z-head"><span class="z-name">' + z.n + '</span>' +
            '<span class="z-bpm">' + hr(z.lo) + '–' + hr(z.hi) + ' bpm</span></div>' +
            '<p class="z-desc">' + z.d + '</p>' +
          '</div>'
        ).join('');

        $('result').classList.remove('calc-hidden');
      }

      $('calcBtn').addEventListener('click', calculate);
      ['age', 'resting'].forEach((id) =>
        $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') calculate(); })
      );
    })();
  </script>
{% endblock %}
