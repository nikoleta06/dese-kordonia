<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% block head_extra0 %}{% endblock %}
  <title>{{ title | safe }}</title>
  <meta name="description" content="{{ description | safe }}">

  {% block head_extra %}{% endblock %}

  <link rel="icon" type="image/x-icon" href="images/favicon.ico?v=2">
  <link rel="icon" type="image/png" sizes="180x180" href="images/favicon.png?v=2">
  <link rel="apple-touch-icon" href="images/favicon.png?v=2">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css?v={{ site.cssVersion }}">

  {% block head_extra2 %}{% endblock %}

  {%- if permalink and permalink != "index.html" and permalink != "index-en.html" %}
  {%- set crumbName = title | replace(" | Δέσε Κορδόνια", "") %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": {% if lang == 'en' %}"Home"{% else %}"Αρχική"{% endif %}, "item": "https://desekordonia.com/{% if lang == 'en' %}index-en.html{% endif %}" },
      {%- if "post-" in permalink %}
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://desekordonia.com/blog{% if lang == 'en' %}-en{% endif %}.html" },
      { "@type": "ListItem", "position": 3, "name": {{ crumbName | dump | safe }}, "item": "https://desekordonia.com/{{ permalink }}" }
      {%- else %}
      { "@type": "ListItem", "position": 2, "name": {{ crumbName | dump | safe }}, "item": "https://desekordonia.com/{{ permalink }}" }
      {%- endif %}
    ]
  }
  </script>
  {%- endif %}
</head>
<body{% if bodyDataPage %} data-page="{{ bodyDataPage }}"{% endif %}>
  <header>
    <div class="nav-inner">
      <a class="brand" href="{{ nav.home.file | navHref(lang) }}">
        <img src="images/logo.png?v=2" alt="{% if lang == 'en' %}Δέσε Κορδόνια logo{% else %}Λογότυπο Δέσε Κορδόνια{% endif %}" class="logo">
        Δέσε<span class="dot">.</span>Κορδόνια
      </a>
      <nav>
        <ul class="menu">
          <li><a href="{{ nav.home.file | navHref(lang) }}" class="home-link{% if nav.home.key == activeNav %} active{% endif %}" aria-label="{{ nav.home[lang] | safe }}" title="{{ nav.home[lang] | safe }}">
            <svg class="home-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span class="home-text">{{ nav.home[lang] | safe }}</span>
          </a></li>
          {% for item in nav.main %}
          <li><a href="{{ item.file | navHref(lang) }}"{% if item.key == activeNav %} class="active"{% endif %}>{{ item[lang] | safe }}</a></li>
          {% endfor %}
          <li class="dropdown{% for item in nav.dropdown %}{% if item.key == activeNav %} active{% endif %}{% endfor %}">
            <button type="button" class="dropdown-toggle" aria-haspopup="true" aria-expanded="false">{% if lang == 'en' %}Tools{% else %}Εργαλεία{% endif %} <span class="caret">▾</span></button>
            <ul class="dropdown-menu">
              {% for item in nav.dropdown %}
              <li><a href="{{ item.file | navHref(lang) }}"{% if item.key == activeNav %} class="active"{% endif %}>{{ item[lang] | safe }}</a></li>
              {% endfor %}
            </ul>
          </li>
          {% for item in nav.secondary %}
          <li><a href="{{ item.file | navHref(lang) }}"{% if item.key == activeNav %} class="active"{% endif %}>{{ item[lang] | safe }}</a></li>
          {% endfor %}
          <li><a href="{{ nav.about.file | navHref(lang) }}"{% if nav.about.key == activeNav %} class="active"{% endif %}>{{ nav.about[lang] | safe }}</a></li>
        </ul>
      </nav>
    </div>
  </header>

  {% block content %}{% endblock %}

  <footer>
    <img src="images/logo-footer.png?v=2" alt="Δέσε Κορδόνια" class="footer-logo">
    <div class="footer-contact">
      <a class="footer-mail" href="mailto:hello@desekordonia.com">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        hello@desekordonia.com
      </a>
    </div>
    <p class="footer-copy">© 2026 <span class="accent">Δέσε Κορδόνια</span></p>
    <p class="footer-links">
      <a href="{{ nav.about.file | navHref(lang) }}">{% if lang == 'en' %}{{ nav.about.enFull }}{% else %}{{ nav.about.elFull }}{% endif %}</a> ·
      <a href="{% if lang == 'en' %}epistimi-trexsimatos-en.html{% else %}epistimi-trexsimatos.html{% endif %}">{% if lang == 'en' %}The Science of Running{% else %}Η Επιστήμη του Τρεξίματος{% endif %}</a> ·
      <a href="{% if lang == 'en' %}privacy-en.html{% else %}privacy.html{% endif %}">{% if lang == 'en' %}Privacy{% else %}Απόρρητο{% endif %}</a>
    </p>
  </footer>

  {% block body_extra %}{% endblock %}

  <script src="js/main.js?v={{ site.jsVersion }}" defer></script>

  {% block scripts_extra %}{% endblock %}
</body>
</html>
