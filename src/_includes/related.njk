{# «Διάβασε επίσης» — στατικά related άρθρα στο build (αντικατέστησε τον JS injector του main.js) #}
{%- set relatedPicks = permalink | relatedPosts -%}
{%- if relatedPicks.length %}
      <section class="related">
        <h3 class="related-title">{% if lang == 'en' %}Read also{% else %}Διάβασε επίσης{% endif %}</h3>
        <div class="related-grid post-grid">
          {%- for p in relatedPicks %}
          {%- set cmeta = postsData.cats[p.cat] %}
          <article class="post-card" data-category="{{ p.cat }}">
            <picture>
              <source type="image/avif" srcset="images/{{ cmeta.img }}.avif?v=1">
              <source type="image/webp" srcset="images/{{ cmeta.img }}.webp?v=1">
              <img src="images/{{ cmeta.img }}.jpg?v=1" alt="{{ p.en if lang == 'en' else p.el }}" loading="lazy" decoding="async" width="400" height="180">
            </picture>
            <div class="post-body">
              <p class="post-meta"><span class="post-cat">{{ cmeta.svg | safe }}{{ cmeta.en if lang == 'en' else cmeta.el }}</span></p>
              <h3>{{ p.en if lang == 'en' else p.el }}</h3>
              <a class="read-more" href="{{ p.slug }}{% if lang == 'en' %}-en{% endif %}.html">{% if lang == 'en' %}Read the article →{% else %}Διάβασε το άρθρο →{% endif %}</a>
            </div>
          </article>
          {%- endfor %}
        </div>
      </section>
{%- endif %}
