---

{% extends "base.njk" %}

{% block head_extra0 %}{% endblock %}

{% block head_extra %}
  <meta name="robots" content="noindex">

  <link rel="canonical" href="https://desekordonia.com/unsubscribe.html">
{% endblock %}

{% block head_extra2 %}{% endblock %}

{% block content %}
  <main>
    <h1 class="section-title">Απεγγραφή από το newsletter</h1>
    <div class="calc">
      <p id="status">Επεξεργασία...</p>
    </div>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);
      const API = (location.hostname === 'localhost') ? 'http://localhost:4000' : 'https://api.desekordonia.com';

      async function run() {
        const token = new URLSearchParams(location.search).get('token');
        if (!token) {
          $('status').textContent = 'Λείπει το token απεγγραφής.';
          return;
        }
        try {
          const r = await fetch(API + '/api/newsletter/unsubscribe/' + encodeURIComponent(token));
          $('status').textContent = r.ok
            ? 'Έγινε! Δεν θα λαμβάνεις πλέον το newsletter.'
            : 'Ο σύνδεσμος δεν είναι έγκυρος ή έχει ήδη χρησιμοποιηθεί.';
        } catch (e) {
          $('status').textContent = "Δεν μπόρεσα να συνδεθώ με τον server. Τρέχει τοπικά;";
        }
      }

      run();
    })();
  </script>
{% endblock %}
