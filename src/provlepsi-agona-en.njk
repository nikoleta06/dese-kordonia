{% block content %}
  <main>
    <h1 class="section-title">Race Time Predictor</h1>
    <p class="lead">
      Recently raced or ran a hard test? Enter your distance and time, and see your
      <strong>estimated time</strong> for the other classic distances — using the established
      Riegel formula, the same one most well-known prediction tools rely on.
    </p>

    <div class="calc">
      <div class="field">
        <label for="dist">Your result's distance</label>
        <select id="dist">
          <option value="5">5 km</option>
          <option value="10" selected>10 km</option>
          <option value="21.0975">Half marathon (21.1 km)</option>
          <option value="42.195">Marathon (42.2 km)</option>
        </select>
      </div>

      <div class="field">
        <label>Your time</label>
        <div class="time-inputs">
          <div><input type="number" id="th" min="0" max="23" step="1" placeholder="0" aria-label="Hours"><small>Hours</small></div>
          <div><input type="number" id="tm" min="0" max="59" step="1" placeholder="52" aria-label="Minutes"><small>Minutes</small></div>
          <div><input type="number" id="ts" min="0" max="59" step="1" placeholder="30" aria-label="Seconds"><small>Seconds</small></div>
        </div>
      </div>

      <button class="btn" id="calcBtn" type="button">Calculate</button>

      <div class="calc-result calc-hidden" id="result">
        <div class="preds" id="preds"></div>
        <p class="image-credit" style="margin-top:1rem;">
          * An estimate, not a promise: it assumes you've also trained appropriately for the
          target distance. The bigger the jump in distance, the bigger the uncertainty — the
          marathon prediction in particular tends to be optimistic without matching preparation.
        </p>
      </div>
    </div>

    <div class="sources">
      <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Sources</h4>
      <p>The scientific basis of this tool:</p>
      <ol>
        <li>Riegel, P. S. (1981). <cite>Athletic records and human endurance.</cite> American Scientist, 69(3), 285–290. <a href="https://pubmed.ncbi.nlm.nih.gov/7235349/" target="_blank" rel="noopener">PubMed →</a></li>
      </ol>
    </div>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);
      const DISTS = [
        { km: 5, name: '5 km' },
        { km: 10, name: '10 km' },
        { km: 21.0975, name: 'Half marathon' },
        { km: 42.195, name: 'Marathon' }
      ];

      function fmtTime(sec) {
        sec = Math.round(sec);
        const h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60), s = sec % 60;
        const mm = String(m).padStart(2, '0'), ss = String(s).padStart(2, '0');
        return h > 0 ? h + ':' + mm + ':' + ss : m + ':' + ss;
      }
      function fmtPace(secPerKm) {
        const m = Math.floor(secPerKm / 60), s = Math.round(secPerKm % 60);
        return m + ':' + String(s).padStart(2, '0');
      }

      function calculate() {
        const d1 = parseFloat($('dist').value);
        const t1 = (parseInt($('th').value) || 0) * 3600 +
                   (parseInt($('tm').value) || 0) * 60 +
                   (parseInt($('ts').value) || 0);
        if (t1 < 60) { alert('Enter a valid time (at least 1 minute).'); return; }

        $('preds').innerHTML = DISTS.map((d) => {
          const isSource = Math.abs(d.km - d1) < 0.01;
          const t2 = isSource ? t1 : t1 * Math.pow(d.km / d1, 1.06); /* Riegel formula */
          const label = isSource
            ? '<span class="p-name">' + d.name + '<span>— your result</span></span>'
            : '<span class="p-name">' + d.name + '</span>';
          return '<div class="pred' + (isSource ? ' p-source' : '') + '">' +
              '<div class="p-head">' + label +
              '<span class="p-time">' + fmtTime(t2) + '</span></div>' +
              '<p class="p-pace">Pace: ' + fmtPace(t2 / d.km) + ' /km</p>' +
            '</div>';
        }).join('');

        $('result').classList.remove('calc-hidden');
      }

      $('calcBtn').addEventListener('click', calculate);
      ['th', 'tm', 'ts'].forEach((id) =>
        $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') calculate(); })
      );
    })();
  </script>
{% endblock %}
