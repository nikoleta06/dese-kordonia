---
permalink: "account.html"
lang: "el"
title: "Ο λογαριασμός μου | Δέσε Κορδόνια"
description: "Το προφίλ σου στο Δέσε Κορδόνια."
---

{% extends "base.njk" %}

{% block head_extra0 %}{% endblock %}

{% block head_extra %}
  <meta name="robots" content="noindex">

  <link rel="canonical" href="https://desekordonia.com/account.html">
  <link rel="alternate" hreflang="el" href="https://desekordonia.com/account.html">
  <link rel="alternate" hreflang="en" href="https://desekordonia.com/account-en.html">
  <link rel="alternate" hreflang="x-default" href="https://desekordonia.com/account.html">
{% endblock %}

{% block head_extra2 %}{% endblock %}

{% block content %}
  <main>
    <h1 class="section-title">Ο λογαριασμός μου</h1>
    <p class="lead calc-hidden" id="intro">Το προφίλ σου.</p>

    <div class="calc calc-hidden" id="form">
      <div class="field">
        <label>Email</label>
        <input type="text" id="email" disabled>
      </div>
      <div class="field">
        <label for="name">Όνομα</label>
        <input type="text" id="name" placeholder="Το όνομά σου">
      </div>
      <div class="field">
        <label for="bio">Λίγα λόγια για σένα</label>
        <input type="text" id="bio" placeholder="π.χ. Τρέχω από το 2023">
      </div>
      <div class="newsletter-box">
        <h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> Newsletter</h4>
        <p>Νέα άρθρα και συμβουλές για το τρέξιμο, κατευθείαν στο email σου.</p>
        <label><input type="checkbox" id="newsletter"> Θέλω να λαμβάνω το newsletter</label>
      </div>

      <button class="btn" id="saveBtn" type="button">Αποθήκευση</button>
      <button class="btn" id="logoutBtn" type="button" style="background:transparent;color:var(--text-dim);box-shadow:none;">Αποσύνδεση</button>
      <button class="btn" id="deleteBtn" type="button" style="background:transparent;color:#e57373;box-shadow:none;">Διαγραφή λογαριασμού</button>

      <div class="calc-result calc-hidden" id="result"></div>
    </div>

    <p id="status">Έλεγχος σύνδεσης...</p>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);
      const API = (location.hostname === 'localhost') ? 'http://localhost:4000' : 'https://api.desekordonia.com';

      function fill(user) {
        $('email').value = user.email;
        $('name').value = user.name || '';
        $('bio').value = user.bio || '';
        $('newsletter').checked = !!user.newsletter_subscribed;
        $('status').classList.add('calc-hidden');
        $('intro').classList.remove('calc-hidden');
        $('form').classList.remove('calc-hidden');
      }

      async function load() {
        try {
          const r = await fetch(API + '/api/auth/me', { credentials: 'include' });
          if (!r.ok) {
            location.href = 'login.html';
            return;
          }
          fill(await r.json());
        } catch (e) {
          $('status').textContent = "Δεν μπόρεσα να συνδεθώ με τον server. Τρέχει τοπικά;";
        }
      }

      async function save() {
        $('saveBtn').disabled = true;
        try {
          const r = await fetch(API + '/api/profile', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              name: $('name').value.trim(),
              bio: $('bio').value.trim(),
              newsletter_subscribed: $('newsletter').checked
            })
          });
          const result = $('result');
          result.classList.remove('calc-hidden');
          result.textContent = r.ok ? 'Αποθηκεύτηκε!' : 'Κάτι πήγε στραβά.';
        } catch (e) {
          const result = $('result');
          result.classList.remove('calc-hidden');
          result.textContent = "Δεν μπόρεσα να συνδεθώ με τον server.";
        }
        $('saveBtn').disabled = false;
      }

      async function logout() {
        try {
          await fetch(API + '/api/auth/logout', { method: 'POST', credentials: 'include' });
        } catch (e) {}
        location.href = 'index.html';
      }

      async function deleteAccount() {
        if (!confirm('Σίγουρα θέλεις να διαγράψεις τον λογαριασμό σου; Θα σβηστούν όλα τα στοιχεία σου και η ενέργεια δεν αναιρείται.')) return;
        $('deleteBtn').disabled = true;
        try {
          await fetch(API + '/api/profile', { method: 'DELETE', credentials: 'include' });
        } catch (e) {}
        location.href = 'index.html';
      }

      $('saveBtn').addEventListener('click', save);
      $('logoutBtn').addEventListener('click', logout);
      $('deleteBtn').addEventListener('click', deleteAccount);
      load();
    })();
  </script>
{% endblock %}
