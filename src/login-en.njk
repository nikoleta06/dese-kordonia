---
permalink: "login-en.html"
lang: "en"
title: "Sign in & Newsletter | Δέσε Κορδόνια"
description: "Sign in to Δέσε Κορδόνια with your email — no password needed — and subscribe to the newsletter."
---

{% extends "base.njk" %}

{% block head_extra0 %}{% endblock %}

{% block head_extra %}
  <meta name="robots" content="noindex">
  <link rel="canonical" href="https://desekordonia.com/login-en.html">
  <link rel="alternate" hreflang="el" href="https://desekordonia.com/login.html">
  <link rel="alternate" hreflang="en" href="https://desekordonia.com/login-en.html">
{% endblock %}

{% block head_extra2 %}{% endblock %}

{% block content %}
  <main>
    <h2 class="section-title">Sign in &amp; Newsletter</h2>
    <p class="lead">
      With your account you subscribe to the Δέσε Κορδόνια <strong>newsletter</strong>
      and manage your profile. Enter your email and we'll send you a sign-in link —
      no password needed.
    </p>

    <ul class="login-perks">
      <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> Get the newsletter with new articles and running tips</li>
      <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg> Set up your profile with your name and a few words about you</li>
      <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.27"/></svg> Unsubscribe from the newsletter anytime, with one click</li>
    </ul>

    <div class="calc">
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" placeholder="you@example.com">
      </div>

      <button class="btn" id="sendBtn" type="button">Send me a link</button>

      <div class="calc-result calc-hidden" id="result"></div>
    </div>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);
      const API = (location.hostname === 'localhost') ? 'http://localhost:4000' : 'https://api.desekordonia.com';

      function showResult(text, isError) {
        const el = $('result');
        el.textContent = text;
        el.classList.remove('calc-hidden');
        el.style.color = isError ? 'var(--accent-2)' : '';
      }

      async function requestLink() {
        const email = $('email').value.trim();
        if (!email || !email.includes('@')) {
          showResult('Enter a valid email.', true);
          return;
        }
        $('sendBtn').disabled = true;
        try {
          const r = await fetch(API + '/api/auth/request-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email })
          });
          if (r.ok) {
            showResult('Check your email for the sign-in link (valid for 15 minutes).', false);
          } else {
            showResult('Something went wrong. Please try again.', true);
          }
        } catch (e) {
          showResult("Couldn't reach the server. Is it running locally?", true);
        }
        $('sendBtn').disabled = false;
      }

      $('sendBtn').addEventListener('click', requestLink);
      $('email').addEventListener('keydown', (e) => { if (e.key === 'Enter') requestLink(); });
    })();
  </script>
{% endblock %}
