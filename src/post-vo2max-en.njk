  <main>
    <article class="article">
      <h1 class="section-title">What is VO₂max and how to improve it</h1>
      <p class="article-meta"><svg style="width:1em;height:1em;vertical-align:-0.15em;margin-right:0.3em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>26 June 2026 · <span class="accent"><svg style="width:1em;height:1em;vertical-align:-0.15em;margin-right:0.25em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5a3 3 0 0 0-3 3 2.5 2.5 0 0 0-2 4 2.5 2.5 0 0 0 1.5 4.5A2.5 2.5 0 0 0 12 19V5z"/><path d="M12 5a3 3 0 0 1 3 3 2.5 2.5 0 0 1 2 4 2.5 2.5 0 0 1-1.5 4.5A2.5 2.5 0 0 1 12 19"/></svg><a href="epistimi-trexsimatos-en.html" style="color:inherit;">Science</a></span> · 5 min read</p>

      <picture>
        <source type="image/avif" srcset="images/cat-science.avif?v=1">
        <source type="image/webp" srcset="images/cat-science.webp?v=1">
