  <script>
    /* Scroll-reveal for the infographics (reuses the global .reveal/.up/.is-visible) */
    (function () {
      var figs = document.querySelectorAll('figure.ig');
      if (!('IntersectionObserver' in window) || !figs.length) return;
      figs.forEach(function (f) { f.classList.add('reveal', 'up'); });
      var io = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      figs.forEach(function (f) { io.observe(f); });
    })();
  </script>
