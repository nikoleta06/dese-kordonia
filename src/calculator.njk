{% extends "base.njk" %}

{% block head_extra0 %}{% endblock %}

{% block head_extra %}
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Υπολογιστής Ρυθμού Τρεξίματος | Δέσε Κορδόνια">
  <meta property="og:description" content="Βάλε απόσταση και χρόνο και δες τον ρυθμό σου ανά χιλιόμετρο και εκτιμώμενους χρόνους για 5K, 10K, ημιμαραθώνιο και μαραθώνιο.">
  <meta property="og:image" content="https://desekordonia.com/images/hero-runner.jpg">
  <meta property="og:url" content="https://desekordonia.com/calculator.html">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="canonical" href="https://desekordonia.com/calculator.html">
{% endblock %}

{% block head_extra2 %}{% endblock %}

{% block content %}
  <main>
    <h1 class="section-title">Υπολογιστής Ρυθμού</h1>
    <p class="lead">
      Βάλε την απόσταση και τον χρόνο σου, και δες τον ρυθμό σου ανά χιλιόμετρο — μαζί με
      εκτιμώμενους χρόνους για τις κλασικές αποστάσεις. Ιδανικό για να βάλεις στόχους!
    </p>

    <div class="calc">
      <div class="field">
        <label for="distance">Απόσταση (χιλιόμετρα)</label>
        <input type="number" id="distance" min="0" step="0.1" placeholder="π.χ. 5">
      </div>

      <div class="field">
        <label>Χρόνος</label>
        <div class="time-inputs">
          <div>
            <input type="number" id="hours" min="0" placeholder="0">
            <small>ώρες</small>
          </div>
          <div>
            <input type="number" id="minutes" min="0" max="59" placeholder="30">
            <small>λεπτά</small>
          </div>
          <div>
            <input type="number" id="seconds" min="0" max="59" placeholder="0">
            <small>δευτ.</small>
          </div>
        </div>
      </div>

      <button class="btn" id="calcBtn" type="button">Υπολόγισε</button>

      <div class="calc-result calc-hidden" id="result">
        <div class="pace">
          <span class="big" id="paceValue">--:--</span>
          <span class="label">ρυθμός ανά χιλιόμετρο</span>
        </div>
        <table>
          <tbody id="predictions"></tbody>
        </table>
        <p class="image-credit" style="margin-top:1rem;">* Οι εκτιμήσεις βασίζονται στον σταθερό ρυθμό σου και είναι ενδεικτικές.</p>
      </div>
    </div>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);

      function fmt(totalSeconds, withHours) {
        totalSeconds = Math.round(totalSeconds);
        const h = Math.floor(totalSeconds / 3600);
        const m = Math.floor((totalSeconds % 3600) / 60);
        const s = totalSeconds % 60;
        const pad = (n) => String(n).padStart(2, '0');
        if (withHours || h > 0) return h + ':' + pad(m) + ':' + pad(s);
        return pad(m) + ':' + pad(s);
      }

      function calculate() {
        const distance = parseFloat($('distance').value);
        const h = parseInt($('hours').value) || 0;
        const m = parseInt($('minutes').value) || 0;
        const s = parseInt($('seconds').value) || 0;
        const totalSeconds = h * 3600 + m * 60 + s;

        if (!distance || distance <= 0 || totalSeconds <= 0) {
          alert('Συμπλήρωσε σωστά την απόσταση και τον χρόνο σου.');
          return;
        }

        const paceSecPerKm = totalSeconds / distance;
        $('paceValue').textContent = fmt(paceSecPerKm, false) + ' /χλμ';

        const targets = [
          { label: '5 χλμ', km: 5 },
          { label: '10 χλμ', km: 10 },
          { label: 'Ημιμαραθώνιος (21,1 χλμ)', km: 21.0975 },
          { label: 'Μαραθώνιος (42,2 χλμ)', km: 42.195 }
        ];

        $('predictions').innerHTML = targets.map((t) =>
          '<tr><td>' + t.label + '</td><td>' + fmt(paceSecPerKm * t.km, true) + '</td></tr>'
        ).join('');

        $('result').classList.remove('calc-hidden');
      }

      $('calcBtn').addEventListener('click', calculate);
      // Enter key triggers calculation
      ['distance', 'hours', 'minutes', 'seconds'].forEach((id) =>
        $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') calculate(); })
      );
    })();
  </script>
{% endblock %}
