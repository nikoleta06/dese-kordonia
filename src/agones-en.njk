{% block head_extra2 %}
  <!-- Leaflet (interactive map) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    #race-map {
      height: 520px;
      width: 100%;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      margin-top: 1.5rem;
      z-index: 1;
    }
    .leaflet-popup-content { font-family: "Inter", sans-serif; }
    .leaflet-popup-content h4 { font-family: "Oswald", sans-serif; margin: 0 0 0.3rem; color: #0f1115; }
    .leaflet-popup-content p { margin: 0 0 0.5rem; color: #333; font-size: 0.9rem; }
    .leaflet-popup-content a { color: #ff5722; font-weight: 600; }
    @media (max-width: 600px) { #race-map { height: 400px; } }

    /* Filters */
    .race-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0 0; }
    .race-filters + .race-filters { margin-top: 0.6rem; }
    .rf-btn { padding: 0.5rem 1rem; border-radius: 999px; border: 1px solid var(--border); background: var(--surface); color: var(--text-dim); cursor: pointer; font-family: inherit; font-size: 0.9rem; transition: color .2s, background-color .2s, border-color .2s; }
    .rf-btn:hover { border-color: var(--accent); color: var(--text); }
    .rf-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }

    /* Legend */
    .map-legend { display: flex; flex-wrap: wrap; gap: 1.2rem; margin-top: 0.8rem; font-size: 0.85rem; color: var(--text-dim); }
    .map-legend span { display: inline-flex; align-items: center; gap: 0.45rem; }
    .leg-dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; border: 2px solid #fff; }

    /* Race cards */
    .race-list { margin-top: 2rem; }
    .race-card .post-body { padding: 1.4rem; }
    .race-card .post-meta { text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.8rem; color: var(--text-dim); margin-bottom: 0.3rem; }
    .race-type { font-weight: 600; }
    .type-road { color: #ff7a50; }
    .type-mountain { color: #3ddc84; }
    .type-ultra { color: #ff6b6b; }
    .race-card h3 { color: var(--text); margin: 0.2rem 0 0.4rem; font-size: 1.2rem; }
    .race-card .race-specs { color: var(--accent-2); font-weight: 600; font-size: 0.88rem; margin-bottom: 0.6rem; }
    .race-card .race-actions { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-top: auto; flex-wrap: wrap; }
    .show-on-map { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 0.85rem; border-radius: 999px; border: 1px solid var(--border); background: none; color: var(--text-dim); cursor: pointer; font-family: "Oswald", sans-serif; font-size: 0.82rem; transition: color .2s, border-color .2s; }
    .show-on-map:hover { border-color: var(--accent); color: var(--accent); }
    .race-card .read-more { color: var(--accent); font-weight: 600; font-family: "Oswald", sans-serif; font-size: 0.85rem; }
    .race-card p.race-note { font-size: 0.82rem; font-style: italic; color: #ffb347; margin-bottom: 0.6rem; }
  </style>
{% endblock %}

{% block content %}
  <main>
    <h1 class="section-title">Running Races — Greece &amp; Europe</h1>
    <p class="lead">
      From the historic Athens Marathon and mountain races in the Greek highlands to Europe's
      major marathons and half marathons. Filter by region and type, click a marker or press
      "Show on map" on a card to focus on a race. Cards are in chronological order — upcoming
      races first.
    </p>

    <div class="race-filters" role="group" aria-label="Region filter">
      <button class="rf-btn active" data-region="all" type="button">All countries</button>
      <button class="rf-btn" data-region="gr" type="button">Greece</button>
      <button class="rf-btn" data-region="eu" type="button">Europe</button>
    </div>
    <div class="race-filters" role="group" aria-label="Type filter">
