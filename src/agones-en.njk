          <p class="race-specs">42.2 km · Road</p>
          <p>The "city of running": a lightning-fast, flat course with a spectacular finish over the water at the City of Arts and Sciences.</p>
          <div class="race-actions">
            <button class="show-on-map" type="button">Show on map</button>
            <a class="read-more" href="https://www.valenciaciudaddelrunning.com/" target="_blank" rel="noopener">Official site →</a>
          </div>
        </div>
      </article>
    </div>

    <p class="plan-note" style="margin-top:1.5rem;">
      <svg style="width:1em;height:1em;vertical-align:-0.15em;margin-right:0.3em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>Dates and registration change every year — the links take you to the official/up-to-date
      information for each race.
    </p>
  </main>
{% endblock %}

{% block body_extra %}{% endblock %}

{% block scripts_extra %}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    (function () {
      if (typeof L === 'undefined') return;
      var COLORS = { road: '#ff5722', mountain: '#2ecc71', ultra: '#e24b4a' };
      var map = L.map('race-map', { scrollWheelZoom: false }).setView([38.7, 23.5], 6);
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap, © CARTO'
      }).addTo(map);

      // Ensure all markers render once layout settles
      map.whenReady(function () { setTimeout(function () { map.invalidateSize(); }, 250); });

      var cards = Array.prototype.slice.call(document.querySelectorAll('.race-card'));
      var entries = [];

      // Chronological order: upcoming races first (rolling from the current month)
      var raceList = document.querySelector('.race-list');
      var thisMonth = new Date().getMonth() + 1;
      cards.sort(function (a, b) {
        return ((a.dataset.month - thisMonth + 12) % 12) - ((b.dataset.month - thisMonth + 12) % 12);
      });
      cards.forEach(function (c) { raceList.appendChild(c); });

      cards.forEach(function (card) {
        var lat = parseFloat(card.dataset.lat), lng = parseFloat(card.dataset.lng);
        if (isNaN(lat) || isNaN(lng)) return;
        var type = card.dataset.type || 'road';
        var name = (card.querySelector('h3') || {}).textContent || '';
        var specs = (card.querySelector('.race-specs') || {}).textContent || '';
        var linkEl = card.querySelector('.read-more');
        var linkHtml = linkEl ? '<a href="' + linkEl.href + '" target="_blank" rel="noopener">' + linkEl.textContent + '</a>' : '';
        var popup = '<h4>' + name + '</h4><p>' + specs + '</p>' + linkHtml;

        var marker = L.circleMarker([lat, lng], {
          radius: 9, color: '#fff', weight: 2,
          fillColor: COLORS[type] || '#ff5722', fillOpacity: 0.95
        }).bindPopup(popup).addTo(map);

        entries.push({ card: card, marker: marker, type: type, region: card.dataset.region || 'gr', lat: lat, lng: lng });

        var btn = card.querySelector('.show-on-map');
        if (btn) btn.addEventListener('click', function () {
          map.flyTo([lat, lng], 11, { duration: 0.8 });
          marker.openPopup();
          document.getElementById('race-map').scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });

      // Combined filtering: region (Greece/Europe) + race type
      var regionBtns = Array.prototype.slice.call(document.querySelectorAll('.rf-btn[data-region]'));
      var typeBtns = Array.prototype.slice.call(document.querySelectorAll('.rf-btn[data-filter]'));
      var curRegion = 'all', curType = 'all';

      function applyFilters(fly) {
        var pts = [];
        entries.forEach(function (e) {
          var show = (curRegion === 'all' || e.region === curRegion) &&
                     (curType === 'all' || e.type === curType);
          e.card.style.display = show ? '' : 'none';
          if (show) { e.marker.addTo(map); pts.push([e.lat, e.lng]); }
          else { map.removeLayer(e.marker); }
        });
        if (fly && pts.length) {
          map.flyToBounds(L.latLngBounds(pts).pad(0.15), { duration: 0.8, maxZoom: 7 });
        }
      }

      regionBtns.forEach(function (b) {
        b.addEventListener('click', function () {
          regionBtns.forEach(function (x) { x.classList.remove('active'); });
          b.classList.add('active');
          curRegion = b.dataset.region;
          applyFilters(true);
        });
      });
      typeBtns.forEach(function (b) {
        b.addEventListener('click', function () {
          typeBtns.forEach(function (x) { x.classList.remove('active'); });
          b.classList.add('active');
          curType = b.dataset.filter;
          applyFilters(true);
        });
      });

      // Initial view: fit all races (Greece + Europe) in frame
      if (entries.length) {
        map.fitBounds(L.latLngBounds(entries.map(function (e) { return [e.lat, e.lng]; })).pad(0.1));
      }
    })();
  </script>
{% endblock %}
